{
  "realm": "ciberisciii_datahub",
  "session": {
    "ssoSessionIdleTimeout": 28800,
    "ssoSessionMaxLifespan": 86400,
    "clientSessionIdleTimeout": 28800,
    "clientSessionMaxLifespan": 86400,
    "accessTokenLifespan": 900,
    "revokeRefreshToken": true,
    "refreshTokenMaxReuse": 0
  },
  "group_root": "use-cases",
  "global_groups": [
    "superusers"
  ],
  "roles": [
    "view",
    "admin"
  ],
  "shared_client_scope": {
    "name": "pathocore-common",
    "audiences": [
      "pathocore-api"
    ],
    "include_identity_claims": true,
    "include_groups": true
  },
  "use_cases": [
    {
      "name": "mepram",
      "labs": [
        "lab1",
        "lab2"
      ]
    },
    {
      "name": "relecov",
      "labs": [
        "lab2",
        "lab3"
      ]
    },
    {
      "name": "redlabra",
      "labs": []
    },
    {
      "name": "ai-models",
      "labs": []
    }
  ],
  "clients": [
    {
      "client_id": "pathocore-web",
      "name": "PathoCore Web",
      "kind": "web",
      "public_client": true,
      "standard_flow_enabled": true,
      "direct_access_grants_enabled": true,
      "redirect_uris": [
        "http://127.0.0.1:3000/auth/callback",
        "http://localhost:3000/auth/callback",
        "http://127.0.0.1:5173/auth/callback",
        "http://localhost:5173/auth/callback"
      ],
      "web_origins": [
        "http://127.0.0.1:3000",
        "http://localhost:3000",
        "http://127.0.0.1:5173",
        "http://localhost:5173"
      ],
      "default_client_scopes": [
        "pathocore-common"
      ]
    },
    {
      "client_id": "pathocore-api",
      "name": "PathoCore API",
      "kind": "api",
      "public_client": false,
      "bearer_only": true,
      "standard_flow_enabled": false,
      "direct_access_grants_enabled": false
    },
    {
      "client_id": "ai-model-api",
      "name": "AI Model API",
      "kind": "api",
      "public_client": false,
      "bearer_only": true,
      "standard_flow_enabled": false,
      "direct_access_grants_enabled": false
    }
  ],
  "users": [
    {
      "username": "mepram_admin",
      "password": "mepram_admin_pass",
      "first_name": "MEPRAM",
      "last_name": "Admin",
      "email": "mepram.admin@example.org",
      "groups": [
        "/use-cases/mepram/labs/lab1/admin",
        "/use-cases/relecov/labs/lab2/view"
      ]
    },
    {
      "username": "relecov_admin",
      "password": "relecov_admin_pass",
      "first_name": "RELECOV",
      "last_name": "Admin",
      "email": "relecov.admin@example.org",
      "groups": [
        "/use-cases/relecov/admin"
      ]
    },
    {
      "username": "redlabra_viewer",
      "password": "redlabra_viewer_pass",
      "first_name": "RedLabRa",
      "last_name": "Viewer",
      "email": "redlabra.viewer@example.org",
      "groups": [
        "/use-cases/redlabra/view"
      ]
    },
    {
      "username": "hybrid_user",
      "password": "hybrid_user_pass",
      "first_name": "Hybrid",
      "last_name": "User",
      "email": "hybrid.user@example.org",
      "groups": [
        "/use-cases/mepram/labs/lab2/view",
