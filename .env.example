# Compose
COMPOSE_PROJECT_NAME=pathocore
APP_UID=1001
APP_GID=1001
HTTP_PORT=8080

# PathoCore API build/runtime
PATHOCORE_API_GIT_REVISION=current
PATHOCORE_API_PORT=8000
PATHOCORE_ENABLE_LEGACY_BASIC_AUTH=true
PATHOCORE_ENABLE_PUBLIC_READ_ENDPOINTS=true
PATHOCORE_RATELIMIT_ENABLED=true
PATHOCORE_RATELIMIT_PUBLIC_RATE=100/m
PATHOCORE_RATELIMIT_AUTHENTICATED_RATE=300/m
PATHOCORE_RATELIMIT_EXPENSIVE_RATE=60/m
PATHOCORE_RATELIMIT_WRITE_RATE=20/m
PATHOCORE_RATELIMIT_IP_META_KEY=
PATHOCORE_RATELIMIT_CACHE=default
PATHOCORE_CREATE_DEFAULT_SUPERUSER=true
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.org
DJANGO_SUPERUSER_PASSWORD=admin_pass
LOAD_INITIAL_TABLES=false

# PathoCore API database
DB_NAME=pathocore_api
DB_USER=pathocore
DB_PASSWORD=pathocore_password
DB_ROOT_PASSWORD=root
DB_PORT_HOST=6606

# MePRAM OMOP API build/runtime and database
MEPRAM_OMOP_API_PORT=8100
MEPRAM_DB_NAME=mepram_omop_api
MEPRAM_DB_USER=mepram
MEPRAM_DB_PASSWORD=mepram_password
MEPRAM_DB_ROOT_PASSWORD=root
MEPRAM_OMOP_DB_PORT_HOST=6608
MEPRAM_API_DEBUG=true
MEPRAM_API_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
MEPRAM_DASHBOARD_SCHEMA=mepram_omop_api
MEPRAM_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
MEPRAM_AUTH_REQUIRED=true
MEPRAM_DOCS_REQUIRE_STAFF=true
MEPRAM_KEYCLOAK_ISSUER=http://127.0.0.1:8080/realms/ciberisciii_datahub
MEPRAM_KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/ciberisciii_datahub/protocol/openid-connect/certs
MEPRAM_KEYCLOAK_AUDIENCE=mepram-api
MEPRAM_KEYCLOAK_CLIENT_ID=pathocore-web
MEPRAM_KEYCLOAK_JWKS_CACHE_TTL_SECONDS=300
MEPRAM_KEYCLOAK_JWKS_TIMEOUT_SECONDS=5

# Keycloak database
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_password
KEYCLOAK_DB_ROOT_PASSWORD=root
KEYCLOAK_DB_PORT_HOST=6607

# Keycloak bootstrap and public URL
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080
KEYCLOAK_PUBLIC_URL=http://127.0.0.1:8080

# Keycloak values consumed by pathocore-api
KEYCLOAK_ISSUER=http://127.0.0.1:8080/realms/ciberisciii_datahub
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/ciberisciii_datahub/protocol/openid-connect/certs
KEYCLOAK_REALM=ciberisciii_datahub
KEYCLOAK_AUDIENCE=pathocore-api
KEYCLOAK_CLIENT_ID=pathocore-web
KEYCLOAK_JWKS_CACHE_TTL_SECONDS=300
KEYCLOAK_JWKS_TIMEOUT_SECONDS=5
KEYCLOAK_ADMIN_BASE_URL=http://keycloak:8080
KEYCLOAK_ADMIN_TOKEN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ADMIN_SEND_ACTION_EMAILS=true
KEYCLOAK_ADMIN_ACTION_EMAIL_REDIRECT_URI=
PATHOCORE_ACCESS_REQUEST_ADMIN_EMAILS=

# Local SMTP catcher used by the test stack
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=no-reply@pathocore.local
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025

# Django host settings generated during API install
LOCAL_SERVER_IP=127.0.0.1
DNS_URL=localhost

# Frontend
PATHOCORE_WEB_PORT=3000
VITE_API_BASE_URL=/api/v1
PATHOCORE_API_PROXY_TARGET=http://pathocore_api:8000
VITE_KEYCLOAK_URL=http://127.0.0.1:8080
VITE_KEYCLOAK_REALM=ciberisciii_datahub
VITE_KEYCLOAK_CLIENT_ID=pathocore-web
VITE_USE_CASE_DATA_MODE=live    # Controls whether to use live data or mock data for use cases. Set to "live" or "simulated".
VITE_USE_CASE_ALERTS_CONTACT_EMAIL=

# API background cache
DATABROWSER_CACHE_SCHEDULER_ENABLED=true
DATABROWSER_CACHE_REFRESH_WEEKDAY=4
DATABROWSER_CACHE_REFRESH_TIME=12:00
DATABROWSER_CACHE_REFRESH_ON_START=false
