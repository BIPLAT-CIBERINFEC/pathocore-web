# Compose
COMPOSE_PROJECT_NAME=pathocore
APP_UID=1001
APP_GID=1001
HTTP_PORT=8080

# PathoCore API build/runtime
PATHOCORE_API_GIT_REVISION=current
PATHOCORE_API_PORT=8000
PATHOCORE_ENABLE_LEGACY_BASIC_AUTH=true
LOAD_INITIAL_TABLES=false

# PathoCore API database
DB_NAME=pathocore_api
DB_USER=pathocore
DB_PASSWORD=pathocore_password
DB_ROOT_PASSWORD=root
DB_PORT_HOST=6606

# Keycloak database
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_password
KEYCLOAK_DB_ROOT_PASSWORD=root
KEYCLOAK_DB_PORT_HOST=6607

# Keycloak bootstrap and public URL
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080
KEYCLOAK_PUBLIC_URL=http://127.0.0.1:8080

# Keycloak values consumed by pathocore-api
KEYCLOAK_ISSUER=http://127.0.0.1:8080/realms/ciberisciii_datahub
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/ciberisciii_datahub/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=pathocore-api
KEYCLOAK_CLIENT_ID=pathocore-web
KEYCLOAK_JWKS_CACHE_TTL_SECONDS=300
KEYCLOAK_JWKS_TIMEOUT_SECONDS=5

# Django host settings generated during API install
LOCAL_SERVER_IP=127.0.0.1
DNS_URL=localhost

# Frontend
PATHOCORE_WEB_PORT=3000
VITE_API_BASE_URL=/api/v1
PATHOCORE_API_PROXY_TARGET=http://pathocore_api:8000
VITE_KEYCLOAK_URL=http://127.0.0.1:8080
VITE_KEYCLOAK_REALM=ciberisciii_datahub
VITE_KEYCLOAK_CLIENT_ID=pathocore-web
VITE_API_BASIC_USERNAME=
VITE_API_BASIC_PASSWORD=
VITE_USE_CASE_DATA_MODE=simulated
VITE_USE_CASE_ALERTS_CONTACT_EMAIL=

# API background cache
DATABROWSER_CACHE_SCHEDULER_ENABLED=true
DATABROWSER_CACHE_REFRESH_WEEKDAY=4
DATABROWSER_CACHE_REFRESH_TIME=12:00
DATABROWSER_CACHE_REFRESH_ON_START=false
